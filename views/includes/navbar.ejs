<style>
/* =========================
   NAVBAR BASE
========================= */

#navigation-bar {
  position: fixed;
  top: 0;
  width: 100%;
  height: 70px;
  backdrop-filter: blur(12px);
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 50px;
  z-index: 1000;
  transition: 0.3s ease;
}

/* =========================
   BRAND
========================= */

.brand {
  display: flex;
  align-items: center;
  gap: 10px;
  font-weight: 700;
  font-size: 22px;
  text-decoration: none;
  color: #2563eb;
  letter-spacing: 0.5px;
}

.brand:hover {
  opacity: 0.8;
}

/* =========================
   NAV LINKS
========================= */

.nav-links {
  display: flex;
  align-items: center;
  gap: 25px;
}

/* Normal Links */

.nav-link {
  position: relative;
  text-decoration: none;
  color: #333;
  font-weight: 500;
  font-size: 15px;
  transition: 0.3s ease;
}

/* Underline animation */
.nav-link::after {
  content: "";
  position: absolute;
  width: 0%;
  height: 2px;
  bottom: -5px;
  left: 0;
  background: #2563eb;
  transition: 0.3s ease;
}

.nav-link:hover::after {
  width: 100%;
}

.nav-link:hover {
  color: #2563eb;
}

/* =========================
   BUTTONS
========================= */

.nav-btn {
  padding: 9px 20px;
  border-radius: 999px;
  text-decoration: none;
  font-size: 14px;
  font-weight: 500;
  transition: 0.3s ease;
  display: inline-flex;
  align-items: center;
  gap: 6px;
}

/* Primary Button */
.primary-btn {
  background: #2563eb;
  color: white;
  box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3);
}

.primary-btn:hover {
  background: #1e40af;
    color: white;
  transform: translateY(-2px);
}

/* Danger Button */
.danger-btn {
  background: #ef4444;
  color: white;
}

.danger-btn:hover {
  background: #dc2626;
  transform: translateY(-2px);
}

/* Outline Button */
.outline-btn {
  border: 2px solid #2563eb;
  color: #2563eb;
}

.outline-btn:hover {
  background: #2563eb;
  color: white;
  transform: translateY(-2px);
}

/* =========================
   HAMBURGER
========================= */

.hamburger {
  display: none;
  font-size: 28px;
  cursor: pointer;
  transition: 0.3s ease;
}

/* =========================
   MOBILE
========================= */

@media (max-width: 768px) {

  #navigation-bar {
    padding: 0 25px;
  }

  .nav-links {
    position: fixed;
    top: 70px;
    right: -100%;
    height: calc(100vh - 70px);
    width: 250px;
    background: white;
    flex-direction: column;
    align-items: flex-start;
    padding: 30px;
    gap: 20px;
    box-shadow: -4px 4px 20px rgba(0,0,0,0.1);
    transition: right 0.3s ease;
  }

  .nav-links.active {
    right: 0;
  }

  .hamburger {
    display: block;
  }
}

</style>


<nav id="navigation-bar">

  <!-- BRAND -->
  <a href="/" class="brand">
    <span class="material-symbols-outlined">home</span>
    RepairNow
  </a>

  <!-- LINKS -->
  <div class="nav-links" id="navLinks">

    <% if (currentRestaurant) { %>
      <a href="/mobileshops" class="nav-btn primary-btn">
        🏪 Visit Shop
      </a>

      <a href="/mobileShop/yourShop/logout"
         class="nav-btn danger-btn">
         ⛔ Close Shop
      </a>
    <% } %>

    <% if (currentUser) { %>
      <a href="/users/logout" class="nav-link">Logout</a>
    <% } %>

    <% if (!currentRestaurant && !currentUser) { %>
      <a href="/users/login" class="nav-link">Login</a>

      <a href="/users/signup" class="nav-btn primary-btn">
        Sign up
      </a>

      <a href="/mobileshops" class="nav-btn outline-btn">
        🛠 Technician Login / Register
      </a>
    <% } %>

  </div>

  <!-- HAMBURGER -->
  <div class="hamburger" id="hamburger">
    ☰
  </div>

</nav>

<script>
  const hamburger = document.getElementById("hamburger");
  const navLinks = document.getElementById("navLinks");

  hamburger.addEventListener("click", () => {
    navLinks.classList.toggle("active");
  });

  document.addEventListener("click", (e) => {
    if (!hamburger.contains(e.target) &&
        !navLinks.contains(e.target)) {
      navLinks.classList.remove("active");
    }
  });
</script>