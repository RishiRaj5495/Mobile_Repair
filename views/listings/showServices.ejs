<script>

function renderTechnicians(technicians) {

   const container = document.querySelector(".priceListContainer");

   container.innerHTML = "";

   technicians.forEach((restaurant) => {

      const card = document.createElement("div");

      card.className = "col-md-6";

      card.innerHTML = `

         <div class="card shop-card h-100 shadow-sm border-0">

            <div class="card-body">

               <div class="d-flex justify-content-between mb-2">

                  <h5 class="fw-bold mb-0">${restaurant.name}</h5>

                  <span class="badge rounded-pill px-3 py-2 bg-success-subtle text-success fw-semibold">
                     ${restaurant.averageRating || "0.0"} ★
                  </span>

               </div>

               <p class="text-muted small">
                  <strong>Address:</strong> ${restaurant.address}
               </p>

               <div class="mt-3">

                  <a href="/shop/${restaurant._id}" class="primary-btn">
                     Forward your issue
                  </a>

               </div>

            </div>

         </div>

      `;

      container.appendChild(card);

   });

}

</script>