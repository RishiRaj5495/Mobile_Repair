<script>
let globalText = "";
let globalIssueData = {};

// 🔹 Upload
async function uploadVideo() {
  const file = document.getElementById("videoInput").files[0];
  if (!file) return alert("Upload video first");

  document.getElementById("loading").style.display = "block";

  const formData = new FormData();
  formData.append("video", file);

  try {
    const res = await fetch("/AI-flow/upload-video", {
      method: "POST",
      body: formData
    });
 console.log("Status:", res.status);

  const text = await res.text();
  console.log("Raw response:", text);

  const data = JSON.parse(text);
  console.log("Parsed data:", data);

    globalText = data.text;
    globalIssueData = data.issueData;

    document.getElementById("text").innerText = data.text;
    document.getElementById("issue").innerText = data.issueData.issue;

    document.getElementById("analysis").classList.remove("hidden");

    // Questions UI (YES/NO buttons instead of text input)
    const form = document.getElementById("questionForm");
    form.innerHTML = "";

    data.questions.forEach((q, i) => {
      form.innerHTML += `
        <div style="margin-bottom:10px;">
          <p>${q}</p>
          <button type="button" onclick="setAnswer(${i}, 'yes')">Yes</button>
          <button type="button" onclick="setAnswer(${i}, 'no')">No</button>
          <span id="ans${i}"></span>
        </div>
      `;
    });

    document.getElementById("questionsDiv").classList.remove("hidden");

  } catch (err) {
    alert("Error processing video");
  } finally {
    document.getElementById("loading").style.display = "none";
  }
}

// store answers
let answers = {};

function setAnswer(index, value) {
  answers[index] = value;
  document.getElementById(`ans${index}`).innerText = `Selected: ${value}`;
}

// 🔹 Submit answers
async function submitAnswers() {
  if (Object.keys(answers).length === 0) {
    return alert("Answer questions first");
  }

  document.getElementById("loading").style.display = "block";

  try {
    const res = await fetch("/refine-issue", {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({
        text: globalText,
        issueData: globalIssueData,
        answers
      })
    });

    const data = await res.json();

    document.getElementById("finalIssue").innerText = data.finalIssue.final_issue;
    document.getElementById("confidence").innerText = data.finalIssue.confidence;
    document.getElementById("fix").innerText = data.finalIssue.recommended_fix;
    document.getElementById("price").innerText = data.estimatedPrice;

    document.getElementById("result").classList.remove("hidden");

  } catch (err) {
    alert("Error getting result");
  } finally {
    document.getElementById("loading").style.display = "none";
  }
}
</script>
<script>
window.addEventListener("load", async () => {

  const permission = await navigator.permissions.query({
    name: "geolocation"
  });

  if(permission.state === "granted") {

    // Location already allowed
    getLocation();

  } else {

    Swal.fire({
      icon: "warning",
      title: "Location Access Needed",
      text: "Please allow location access to see nearby technicians.",
