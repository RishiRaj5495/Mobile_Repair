<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    /* font-family:Inter,sans-serif; */
}

body{
        background:linear-gradient(180deg,#eef5ff,#f8fafc);

}

.tracking-container{
    display:flex;
    height:100vh;
    overflow:hidden;
}

.info-section{
    width:380px;
    min-width:380px;
    background:#f8fafc;
    border-right:1px solid #e5e7eb;
    padding:20px;
    overflow-y:auto;
    scroll-behavior:smooth;
}

.info-section::-webkit-scrollbar{
    width:8px;
}

.info-section::-webkit-scrollbar-thumb{
    background:#cbd5e1;
    border-radius:10px;
}

.map-section{
    flex:1;
    padding:20px;
}

#map{
    width:100%;
    height:100%;
    border-radius:18px;
}

.card{
    background:#fff;
    border-radius:18px;
    padding:20px;
    margin-bottom:18px;
    box-shadow:
        0 6px 18px rgba(0,0,0,.06);
    transition:.25s;
}

.card:hover{
    transform:translateY(-4px);
    box-shadow:
        0 12px 28px rgba(0,0,0,.12);
}

.card h2{
    font-size:19px;
    font-weight:700;
    margin-bottom:18px;
    color:#111827;
}

.card:first-child{
    position:sticky;
    top:0;
    z-index:20;
    background:white;
}
.badge{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    padding:12px 22px;
    border-radius:50px;
    font-size:15px;
    font-weight:700;
    letter-spacing:.4px;
}

.pending_technician{
    background:#fff3cd;
    color:#856404;
}

.accepted{
    background:#d4edda;
    color:#155724;
}

.travelling{
    background:#cce5ff;
    color:#004085;
}

.arrived{
    background:#d1ecf1;
    color:#0c5460;
}

.repairing{
    background:#f8d7da;
    color:#721c24;
}

.completed{
    background:#d4edda;
    color:#155724;
}

.cancelled{
    background:#f5c6cb;
    color:#721c24;
}

.detail-row{
    display:flex;
    justify-content:space-between;
    align-items:flex-start;
    gap:10px;
    padding:8px 0;
    border-bottom:1px solid #f1f5f9;
}

.call-btn{
    display:flex;
    justify-content:center;
    align-items:center;
    gap:8px;

    width:100%;
    padding:14px;

    border-radius:12px;

    background:#2563eb;
    color:white;

    text-decoration:none;

    font-weight:600;

    transition:.3s;
}

.call-btn:hover{
    background:#1d4ed8;
}

.tracking-box{
    text-align:center;
}

.tracking-box h3{
    font-size:28px;
    margin-bottom:6px;
    color:#2563eb;
}

.notification{
    background:#f8fafc;
    border-left:5px solid #2563eb;
    padding:12px;
    border-radius:10px;
    margin-bottom:12px;
}
.timeline{
    position:relative;
    margin-top:10px;
}

.timeline::before{
    content:"";
    position:absolute;
    left:11px;
    top:0;
    bottom:0;
    width:3px;
    background:#22c55e;
}

.timeline-step{
    position:relative;
    padding-left:35px;
    margin-bottom:20px;
    line-height:1.6;
}

.timeline-step::before{
    content:"";
    position:absolute;
    left:3px;
    top:4px;
    width:18px;
    height:18px;
    border-radius:50%;
    background:#22c55e;
    border:4px solid white;
}
video{
    background:black;
}
.tracking-box{
    text-align:center;
}

.tracking-box h3{
    font-size:34px;
    color:#2563eb;
}

.tracking-box p{
    color:#6b7280;
}

#distance,
#eta{
    margin-bottom:8px;
}
@media (max-width:992px){

.tracking-container{
    flex-direction:column;
    height:auto;
}

.info-section{
    width:100%;
    min-width:100%;
    border-right:none;
    padding:15px;
}

.map-section{
    width:100%;
}

#map{
    height:350px;
}

}
@media (max-width:576px){

.card{
    padding:16px;
    border-radius:14px;
}

.card h2{
    font-size:17px;
}

.tracking-box h3{
    font-size:28px;
}

.badge{
    width:100%;
}

.call-btn{
    font-size:15px;
}

.timeline-step{
    font-size:14px;
}

.detail-row{
    font-size:14px;
}

video{
    max-height:180px;
}

}
</style>

<div class="tracking-container">

    <!-- LEFT PANEL -->
    <div class="info-section">

        <!-- BOOKING STATUS -->
        <div class="card">
            <h2>📋 Booking Status</h2>

            <span id="bookingStatus" class="badge <%= order.status %>">
                <%= order.status.replaceAll('_',' ') %>
            </span>
            
        </div>

        <!-- LIVE TRACKING -->
        <div class="card tracking-box">
            <h2>🛰 Live Tracking</h2>

            <h3 id="distance">---</h3>
          
            <p>Distance Away</p>

            <br>

            <h3 id="eta">---</h3>
             
            <p>Estimated Arrival</p>
        </div>

        <!-- REPAIR PROGRESS -->
        <div class="card">
            <h2>🚀 Repair Progress</h2>

            <div class="timeline">

                <div class="timeline-step">
                    ✓ Request Submitted
                </div>

                <div class="timeline-step">
                    ✓ Payment Completed
                </div>

                <div class="timeline-step">
                    👨‍🔧 Technician Assigned
                </div>

                <div class="timeline-step">
                    🛵 Travelling
                </div>

                <div class="timeline-step">
                    📍 Arrived
                </div>

                <div class="timeline-step">
                    🔧 Repairing
                </div>

                <div class="timeline-step">
                    🎉 Completed
                </div>

            </div>
        </div>

        <!-- TECHNICIAN -->
        <div class="card">
            <h2>👨‍🔧 Technician Details</h2>

            <div class="detail-row">
                <strong>Name:</strong>
                <%= order.restaurant.name %>
            </div>

            <div class="detail-row">
                <strong>Phone:</strong>
                <%= order.restaurant.phone %>
            </div>

            <div class="detail-row">
                <strong>Rating:</strong>
                <%= order.restaurant.averageRating.toFixed(1) %> ⭐
            </div>

            <a href="tel:<%= order.restaurant.phone %>" class="call-btn">
                📞 Call Technician
            </a>
        </div>

        <!-- CUSTOMER DETAILS -->
        <div class="card">
            <h2>👤 Customer Details</h2>

            <div class="detail-row">
                <strong>Name:</strong>
                <%= order.customerFirstName %> <%= order.customerLastName %>
            </div>

            <div class="detail-row">
                <strong>Phone:</strong>
                <%= order.customerPhone %>
            </div>

            <div class="detail-row">
                <strong>Email:</strong>
                <%= order.customerEmail %>
            </div>

            <div class="detail-row">
                <strong>Address:</strong>
                <%= order.customerAddress %>
            </div>

            <div class="detail-row">
                <strong>Ticket ID:</strong>
                <%= order.ticketId %>
            </div>

           <div class="detail-row">
    <strong>Payment:</strong>

    <% if (order.paymentStatus === "paid") { %>
        ₹<%= order.advanceAmount %> Advance Paid
    <% } else if (order.paymentStatus === "pending") { %>
        ₹<%= order.advanceAmount %> Payment Pending
    <% } else if (order.paymentStatus === "refunded") { %>
        ₹<%= order.advanceAmount %> Refunded
    <% } %>
</div>

            <div class="detail-row">
                <strong>Created:</strong>
                <%= order.createdAt.toLocaleString() %>
            </div>
        </div>

        <!-- ISSUE VIDEO -->
        <div class="card">
            <h2>🎥 Issue Video</h2>

            <video controls>
                <source src="<%= order.video.url %>" type="video/mp4">
            </video>
        </div>

        <!-- NOTIFICATIONS -->
        <div class="card">
            <h2>🔔 Notifications</h2>

            <div id="notifications">

                <div class="notification">
                    ✓ Request Submitted
                </div>

                <div class="notification">
                    ✓ Payment Successful
                </div>

                <div class="notification">
                    ✓ Waiting For Technician
                </div>

            </div>
        </div>

    </div>

    <!-- RIGHT PANEL -->
    <div class="map-section">
        <div id="map"></div>
    </div>

</div>


  

